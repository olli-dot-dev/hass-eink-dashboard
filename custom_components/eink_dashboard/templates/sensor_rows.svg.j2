{%- from "_macros.svg.j2" import widget_title, card_container,
    card_row -%}
<svg xmlns="http://www.w3.org/2000/svg"
     width="{{ w }}" height="{{ h }}">
<rect width="{{ w }}" height="{{ h }}" fill="white"/>
{%- if has_entities -%}
{{ widget_title(title, title_font_sz) }}
{%- call card_container(
    x=0, y=content_y, w=w, h=content_h,
    card_style=card_style,
    radius=m_radius, border=m_border,
    bar_width=bar_width) -%}
{%- for row in rows -%}
{{ card_row(
    x=x_off, y=row.y,
    w=w - x_off - r_inset, row_h=row_h,
    padding=m_padding, icon_dia=m_icon_dia,
    inner_gap=m_inner_gap, border=m_border,
    font_primary=m_font_primary,
    font_secondary=m_font_secondary,
    primary=row.primary,
    secondary=row.secondary,
    icon_svg=row.icon_svg,
    letter=row.letter,
    lpad=lpad, rpad=rpad) }}
{%- if not loop.last -%}
<line
  x1="{{ x_off + lpad }}"
  y1="{{ row.y + row_h }}"
  x2="{{ w - r_inset - rpad }}"
  y2="{{ row.y + row_h }}"
  stroke="#787878"
  stroke-width="{{ m_divider }}"/>
{%- endif -%}
{%- endfor -%}
{%- endcall -%}
{%- endif -%}
</svg>
